# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Session signing — must be at least 32 characters, generate with: openssl rand -base64 32
SESSION_SIGNING_SECRET=

# Upstash Redis — for rate limiting and session revocation cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Demo household — UUID of the permanent demo household (set after running supabase/seed.sql)
# After seeding: SELECT id FROM households WHERE is_demo = true;
# Default seed.sql value: 00000000-0000-0000-0000-000000000000
DEMO_HOUSEHOLD_ID=

# Cron jobs — secret token for protected cron route handlers
CRON_SECRET=
