# Environnement E2E (Playwright + Supabase local + Redis local).
# Copier vers .env.test.local (gitignoré) : cp .env.test.example .env.test.local
# Les valeurs ci-dessous fonctionnent telles quelles avec la stack locale par
# défaut (`npm run test:e2e:setup`) — rien ici n'est secret.

# Supabase local. Les clés sont celles imprimées par `supabase start` —
# laissées vides ici (la protection anti-secrets GitHub bloque leur motif,
# même s'il s'agit des valeurs locales par défaut) : `npm run test:e2e:setup`
# les remplit automatiquement dans .env.test.local.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Signature des cookies de session (≥ 32 caractères, valeur de test)
SESSION_SIGNING_SECRET=e2e-test-signing-secret-0123456789abcdef

# Foyer démo créé par scripts/seed-e2e.mjs
DEMO_HOUSEHOLD_ID=00000000-0000-0000-0000-000000000000

# Redis local derrière un proxy REST compatible Upstash (conteneurs
# mijote-e2e-redis + mijote-e2e-srh, démarrés par test:e2e:setup).
# Nécessaire : les routes join/lookup ne sont PAS fail-open sans Redis.
UPSTASH_REDIS_REST_URL=http://127.0.0.1:8079
UPSTASH_REDIS_REST_TOKEN=e2e-local-token

# Clés factices : le client OpenAI doit être constructible, mais tout appel
# accidentel échoue en 401 (aucune dépense). Les flows IA sont hors périmètre E2E.
OPENAI_SERVICE_KEY=sk-e2e-dummy
OPENAI_ADMIN_KEY=sk-e2e-dummy
APIFY_TOKEN=

# Divers (valeurs inertes)
CRON_SECRET=e2e-cron-secret
ADMIN_HOUSEHOLD_IDS=
NEXT_PUBLIC_SENTRY_DSN=
